# Application
APP_NAME=InsightHub AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True
WORKERS=4

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# API Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# External APIs - Open-Meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1
OPEN_METEO_AQI_URL=https://air-quality-api.open-meteo.com/v1
OPEN_METEO_TIMEOUT=30
OPEN_METEO_MAX_RETRIES=3

# Scheduler
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC
WEATHER_FETCH_INTERVAL_MINUTES=60
AQI_FETCH_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Data Retention (days)
FORECAST_RETENTION_DAYS=30
API_LOG_RETENTION_DAYS=90
SCHEDULER_LOG_RETENTION_DAYS=90

# Cache (Future)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=300
